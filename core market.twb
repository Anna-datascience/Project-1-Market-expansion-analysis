            </column>
            <column caption='Star Rating' datatype='string' name='[Calculation_1469233835196434]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='CASE [review_score]&#13;&#10;when 5 Then &apos;★★★★★&apos;&#13;&#10;when 4 Then &apos;★★★★☆&apos;&#13;&#10;when 3 Then &apos;★★★☆☆&apos;&#13;&#10;when 2 Then &apos;★★☆☆☆&apos;&#13;&#10;when 1 Then &apos;★☆☆☆☆&apos;&#13;&#10;END' />
